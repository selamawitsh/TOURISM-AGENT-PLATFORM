APP_NAME=auth-service           
APP_ENV=development             
APP_PORT=8081                   

# DATABASE SETTINGS
# ----------------------
# Format: postgres://username:password@host:port/database?options
# Username: selam
# Password: selam123
# Host: localhost 
# Port: 5432 (default PostgreSQL port)
# Database: tourism_auth_db
# sslmode=disable (only for development)
DATABASE_URL=postgres://selam:selam123@localhost:5432/tourism_auth_db?sslmode=disable

# JWT (JSON WEB TOKEN) SETTINGS

JWT_SECRET=tourism@1234567890             
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=15    
JWT_REFRESH_TOKEN_EXPIRES_HOURS=168    

# CORS (CROSS-ORIGIN RESOURCE SHARING)
FRONTEND_URL=http://localhost:5173    