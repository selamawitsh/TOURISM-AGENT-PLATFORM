# AI Service .env example
AI_SERVICE_PORT=8090
LLM_PROVIDER=openai
# Set your OpenAI API key (do NOT commit real keys)
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_EMBED_MODEL=text-embedding-3-small

# Service endpoints
DESTINATION_SERVICE_URL=http://localhost:8083
BOOKING_SERVICE_URL=http://localhost:8084
