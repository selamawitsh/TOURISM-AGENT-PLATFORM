# Environment
APP_ENV=development

# Service URLs
AUTH_SERVICE_URL=http://localhost:8081
USER_SERVICE_URL=http://localhost:8082
DESTINATION_SERVICE_URL=http://localhost:8083
BOOKING_SERVICE_URL=http://localhost:8084
FAVORITES_SERVICE_URL=http://localhost:8085
REVIEW_SERVICE_URL=http://localhost:8086
PAYMENT_SERVICE_URL=http://localhost:8087
ANALYTICS_SERVICE_URL=http://localhost:8088